# ---- Python ----
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ---- Swift / SwiftPM build output ----
.build/
.swiftpm/
DerivedData/
*.xcodeproj/xcuserdata/
Package.resolved

# ---- Built app bundles (produced by build.sh; reproducible) ----
*.app/

# ---- External clones (re-created by install.sh; ~1GB of third-party repos) ----
ext/

# ---- Model weights / caches (live in ~/.cache/huggingface, never here) ----
*.safetensors
*.gguf
*.mlx
*.npz
*.bin

# ---- Murmur Solo: on-device model + built whisper.cpp lib ----
# Model (~1.6GB) is downloaded per murmur-solo/README; the static lib is
# reproduced by murmur-solo/build-whisper.sh. Vendored headers ARE committed.
murmur-solo/Models/
murmur-solo/Frameworks/whisper/lib/
murmur-solo/*.dmg

# ---- Murmur WK: bundled CoreML model + tokenizer (downloaded per README) ----
murmur-wk/Models/
murmur-wk/*.dmg

# ---- Audio artifacts (recordings / TTS output / benchmark samples) ----
*.wav
*.mp3
*.flac

# ---- macOS / editor cruft ----
.DS_Store
*.swp
*~
